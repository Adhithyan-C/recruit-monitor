# Server Port
PORT=4000

# JWT signing secret — must be at least 32 characters
JWT_SECRET=your_jwt_secret_here_minimum_32_chars

# Allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGIN_PROD=https://yourapp.vercel.app

# Agora RTC App ID — from Agora console
AGORA_APP_ID=your_agora_app_id_here

# Deepgram API Key — server-side speech-to-text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Supabase Project URL — from Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — used for signInWithPassword
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key — used for admin user operations. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
