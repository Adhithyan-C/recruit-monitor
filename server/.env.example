# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────
# Use the DIRECT (non-pooled) connection string from:
# Supabase Dashboard → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=your_jwt_secret_here_minimum_32_chars
JWT_EXPIRES_IN=15m

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Agora ─────────────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id_here
# Enable App Certificate in Agora Console → Project → Security → App Certificate
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here
AGORA_TOKEN_TTL_SECONDS=3600

# ── Deepgram ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:5173

# ── Presence / Meeting tuning (defaults shown) ────────────────────────
GRACE_WINDOW_SECONDS=30
CLAIM_TTL_SECONDS=60
PRESENCE_HEARTBEAT_INTERVAL_SECONDS=10
PRESENCE_STALE_AFTER_SECONDS=30
PRESENCE_SWEEPER_INTERVAL_SECONDS=15
